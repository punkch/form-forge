        },
        {
          "id": "household_survey_n11",
          "name": "member_sex",
          "bind": {},
          "body": {},
          "kind": "question",
          "type": "select_one",
          "label": {
            "English (en)": "Sex",
            "French (fr)": "Sexe"
          },
          "listRef": "sex"
        }
      ]
    },
    {
      "id": "household_survey_n12",
