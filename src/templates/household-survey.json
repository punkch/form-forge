      "name": "intro",
      "bind": {},
      "body": {},
      "kind": "question",
      "type": "note",
      "label": {
        "English (en)": "Household survey — one interview per household with the head of household or another adult member.",
        "French (fr)": "Enquête ménage — un entretien par ménage avec le chef de ménage ou un autre membre adulte."
      }
    },
    {
      "id": "household_survey_n2",
      "name": "interview_date",
      "bind": {
        "required": "true()"
