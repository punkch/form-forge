      "label": {
        "English (en)": "Date of interview",
        "French (fr)": "Date de l'entretien"
      }
    },
    {
      "id": "household_survey_n3",
      "name": "region",
      "bind": {
        "required": "true()"
      },
      "body": {},
      "kind": "question",
