        "constraintMessage": {
          "English (en)": "Household size must be between 1 and 50.",
          "French (fr)": "La taille du ménage doit être comprise entre 1 et 50."
        }
      },
      "body": {},
      "kind": "question",
      "type": "integer",
      "label": {
        "English (en)": "How many people live in this household?",
        "French (fr)": "Combien de personnes vivent dans ce ménage ?"
