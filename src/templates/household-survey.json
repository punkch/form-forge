          "body": {},
          "kind": "question",
          "type": "text",
          "label": {
            "English (en)": "Member name",
            "French (fr)": "Nom du membre"
          }
        },
        {
          "id": "household_survey_n10",
          "name": "member_age",
          "bind": {
            "constraint": ". >= 0 and . <= 120",
