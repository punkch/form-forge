<?xml version="1.0"?><h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:odk="http://www.opendatakit.org/xforms"><h:head><h:title>Basic Test</h:title><model odk:xforms-version="1.0.0"><instance><data id="basic_test" version="20260709"><respondent_name/><age/><height>1.5</height><intro_note/><birth_year/><visit_date/><consent/><symptoms/><meta><instanceID/></meta></data></instance><instance id="yes_no"><root><item><name>yes</name><label>Yes</label></item><item><name>no</name><label>No</label></item></root></instance><instance id="symptoms"><root><item><name>fever</name><label>Fever</label></item><item><name>cough</name><label>Cough</label></item><item><name>none</name><label>None</label></item></root></instance><bind nodeset="/data/respondent_name" type="string" required="true()" constraint="string-length(.) &gt; 1" jr:constraintMsg="Name is too short"/><bind nodeset="/data/age" type="int" required="true()" constraint=". &gt;= 0 and . &lt;= 120" jr:constraintMsg="Age must be 0-120"/><bind nodeset="/data/height" type="decimal" relevant=" /data/age  &gt;= 18"/><bind nodeset="/data/intro_note" readonly="true()" type="string"/><bind nodeset="/data/birth_year" type="string" calculate="2026 -  /data/age "/><bind nodeset="/data/visit_date" type="date"/><setvalue ref="/data/visit_date" event="odk-instance-first-load" value="today()"/><bind nodeset="/data/consent" type="string" required="true()"/><bind nodeset="/data/symptoms" type="string"/><bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/></model></h:head><h:body><input ref="/data/respondent_name"><label>What is your name?</label><hint>Full legal name</hint></input><input ref="/data/age" appearance="thousands-sep"><label>How old are you?</label></input><input ref="/data/height"><label>Height in meters</label></input><input ref="/data/intro_note"><label> Thank you <output value=" /data/respondent_name "/>! </label></input><input ref="/data/visit_date"><label>Date of visit</label></input><select1 ref="/data/consent"><label>Do you consent?</label><itemset nodeset="instance('yes_no')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select ref="/data/symptoms" appearance="minimal"><label>Any symptoms?</label><itemset nodeset="instance('symptoms')/root/item"><value ref="name"/><label ref="label"/></itemset></select></h:body></h:html>