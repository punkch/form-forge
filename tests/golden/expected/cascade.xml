<?xml version="1.0"?><h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:odk="http://www.opendatakit.org/xforms"><h:head><h:title>Cascade Test</h:title><model odk:xforms-version="1.0.0"><instance><data id="cascade_test" version="20260709"><state/><district/><village/><shuffled/><meta><instanceID/></meta></data></instance><instance id="villages" src="jr://file-csv/villages.csv"/><instance id="state"><root><item><name>north</name><label>North</label></item><item><name>south</name><label>South</label></item></root></instance><instance id="district"><root><item><name>n1</name><label>North One</label><state>north</state></item><item><name>n2</name><label>North Two</label><state>north</state></item><item><name>s1</name><label>South One</label><state>south</state></item></root></instance><instance id="colors"><root><item><name>red</name><label>Red</label></item><item><name>blue</name><label>Blue</label></item></root></instance><bind nodeset="/data/state" type="string"/><bind nodeset="/data/district" type="string"/><bind nodeset="/data/village" type="string"/><bind nodeset="/data/shuffled" type="string"/><bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/></model></h:head><h:body><select1 ref="/data/state"><label>State?</label><itemset nodeset="instance('state')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/district"><label>District?</label><itemset nodeset="instance('district')/root/item[state= /data/state ]"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/village"><label>Village?</label><itemset nodeset="instance('villages')/root/item"><value ref="name"/><label ref="label"/></itemset></select1><select1 ref="/data/shuffled"><label>Random color?</label><itemset