{
  "name": "form-forge",
  "description": "Form Forge for ODK — visual form builder, purely client-side, imports/exports XForm XML and XLSForm, live ODK Web Forms preview",
  "version": "1.0.0-RC3",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "odk",
    "xform",
    "xlsform",
    "form-builder",
    "vue",
    "data-collection",
    "offline-first"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b",
    "lint": "eslint . && pnpm lint:css",
    "lint:css": "stylelint \"src/**/*.{css,vue}\"",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify:webforms": "node scripts/verify-webforms-bundle.mjs",
    "generate:theme": "node scripts/generate-theme-css.mjs"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.0",
    "@getodk/web-forms": "1.0.0",
    "@primeuix/themes": "1.0.3",
    "dexie": "^4.4.4",
    "jszip": "^3.10.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "4.3.3",
    "vue": "^3.5.39",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.5.0",
    "write-excel-file": "^4.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "@xmldom/xmldom": "^0.9.8",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^4.0.0",
    "happy-dom": "^20.10.6",
    "neostandard": "^0.13.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.14.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "typescript": "~5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7",
    "workbox-window": "^7.4.1"
  },
  "pnpm": {
    "overrides": {
      "@primeuix/styles": "1.0.3",
      "@primeuix/styled": "0.5.1",
      "@primeuix/utils": "0.5.4"
    }
  }
}
